<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admission Form - The Study Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* --- A4 PRINT LAYOUT STYLES --- */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        
        body { 
            background: #555; 
            display: flex; 
            justify-content: center; 
            padding: 20px;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .a4-paper {
            background: white; 
            width: 210mm; 
            height: auto; 
            min-height: 297mm; 
            padding-top: 15mm; padding-left: 10mm; padding-right: 10mm; padding-bottom: 10mm; 
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3); 
            overflow: visible; 
        }

        .form-border { 
            border: 3px double #000; 
            height: auto;
            min-height: 1000px; 
            padding: 15px; 
            position: relative; 
            border-radius: 15px; 
            display: flex; 
            flex-direction: column; 
            justify-content: space-between; 
        }

        .watermark {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 350px; opacity: 0.08; pointer-events: none; z-index: 0;
        }

        .uppercase-mode { text-transform: uppercase; }
        input, select, textarea { text-transform: uppercase; }

        header { 
            display: flex; justify-content: space-between; align-items: center; 
            border-bottom: 2px solid #000; padding-bottom: 8px; margin-bottom: 10px; 
            position: relative; z-index: 1; 
        }
        .logo-box img { height: 65px; } 
        
        .title-box { text-align: center; flex-grow: 1; }
        .title-box h1 { color: #000; font-size: 28px; font-weight: 900; margin-bottom: 2px; line-height: 1; }
        .title-box h3 { background: #000 !important; color: white !important; display: inline-block; padding: 4px 20px; border-radius: 15px; font-size: 14px; letter-spacing: 1px; font-weight: 800; }
        
        .reg-box { border: 2px solid #000; padding: 5px; text-align: center; background: #fff; border-radius: 5px; }
        .reg-box label { font-size: 9px; font-weight: 800; display: block; color: #000; }
        .reg-box input { border: none; background: transparent; font-weight: 800; color: #000; text-align: center; font-size: 14px; outline: none; width: 110px; }

        .section-header {
            background: #000 !important; color: white !important; padding: 5px 10px; 
            font-size: 13px; font-weight: 800; margin-bottom: 8px; border-radius: 4px; 
            display: flex; justify-content: space-between; align-items: center;
        }

        .form-grid { display: grid; grid-template-columns: 2.2fr 1fr; gap: 20px; margin-bottom: 5px; position: relative; z-index: 1; }
        .fields-container { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 15px; }
        .full-width { grid-column: span 2; }

        .input-group { margin-bottom: 1px; }
        .input-group label { font-size: 10px; font-weight: 700; color: #000; display: block; margin-bottom: 1px; }
        .input-group input, .input-group select {
            width: 100%; border: none; border-bottom: 1px dashed #000;
            padding: 4px 0; font-size: 13px; font-weight: 700; outline: none; background: transparent; color: #000;
        }
        .input-group input:focus { border-bottom: 2px solid #000; }

        input[type="date"]::-webkit-inner-spin-button,
        input[type="date"]::-webkit-calendar-picker-indicator { display: none !important; -webkit-appearance: none !important; }
        select { -webkit-appearance: none; -moz-appearance: none; appearance: none; }

        .prefix-input { display: flex; align-items: center; border-bottom: 1px dashed #000; padding-bottom: 2px; }
        .prefix-input span { font-size: 13px; font-weight: 800; color: #000; margin-right: 5px; min-width: 30px;}
        .prefix-input input { border: none; flex-grow: 1; width: 100%; border-bottom: none; padding: 0;}

        .photo-box {
            border: 2px dashed #000; height: 150px; width: 130px;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; cursor: pointer; margin: 0 auto; position: relative; background: #f0f0f0;
        }
        .photo-box img { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; display: none; }
        .photo-box p { font-size: 9px; color: #000; font-weight: bold; padding: 5px; }

        .form-footer {
            margin-top: 5px; border-top: 2px solid #000; padding-top: 8px;
            text-align: center; font-size: 11px; color: #000; position: relative; z-index: 1; font-weight: 900;
        }
        
        .signatures { display: flex; justify-content: space-between; margin-top: 140px; margin-bottom: 15px; }
        .sig-line { border-top: 1px solid #000; width: 150px; text-align: center; padding-top: 5px; font-size: 11px; font-weight: bold; text-transform: none; color: #000; }

        .control-bar {
            position: fixed; top: 20px; right: 20px; background: white; padding: 15px; border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2); z-index: 1000; display: flex; flex-direction: column; gap: 10px;
        }
        .btn { padding: 10px 20px; border: none; color: white; font-weight: bold; cursor: pointer; border-radius: 5px; }
        .btn-save { background: #000; }
        .btn-print { background: #555; }
        .status-msg { font-size: 12px; font-weight: bold; text-align: center; margin-top: 5px; }

        @media print {
            body { background: white; padding: 0; display: block; }
            .a4-paper { box-shadow: none; border: none; width: 100%; height: auto; min-height: 297mm; margin: 0; }
            .control-bar { display: none; }
            @page { margin: 0; size: A4; }
        }
    </style>
</head>
<body>

    <div class="control-bar">
        <button id="saveBtn" class="btn btn-save" onclick="saveToCloud()">Save & Register</button>
        <p id="statusMsg" class="status-msg"></p>
        <button class="btn btn-print" onclick="window.print()">Print Form</button>
    </div>

    <div class="a4-paper uppercase-mode">
        <div class="form-border">
            <img src="Logo.png" alt="Watermark" class="watermark">
            <div> 
                <header>
                    <div class="logo-box"><img src="Logo.png" alt="Logo"></div>
                    <div class="title-box">
                        <h1>The Study Home</h1>
                        <h3>ADMISSION FORM</h3>
                    </div>
                    <div class="reg-box">
                        <label>REGISTRATION ID</label>
                        <input type="text" id="regId" readonly value="LOADING...">
                    </div>
                </header>

                <div class="section-header">
                    <span><i class="fa-solid fa-user"></i> 01. STUDENT INFORMATION</span>
                    <span id="sessionDisplay" style="font-size: 12px; font-weight: 800;">SESSION: 2025-26</span>
                </div>

                <div class="form-grid">
                    <div class="fields-container">
                        <div class="input-group full-width">
                            <label>STUDENT'S FULL NAME</label>
                            <input type="text" id="studentName" required oninput="this.value = this.value.toUpperCase()">
                        </div>
                        <div class="input-group">
                            <label>ADMISSION DATE</label>
                            <input type="date" id="admissionDate" required>
                        </div>
                        <div class="input-group">
                            <label>DATE OF BIRTH</label>
                            <input type="date" id="dob" required>
                        </div>
                        
                        <div class="input-group">
                            <label>FATHER'S NAME</label>
                            <div class="prefix-input"><span>MR.</span><input type="text" id="fatherName" oninput="this.value = this.value.toUpperCase()"></div>
                        </div>
                        <div class="input-group">
                            <label>MOTHER'S NAME</label>
                            <div class="prefix-input"><span>MRS.</span><input type="text" id="motherName" oninput="this.value = this.value.toUpperCase()"></div>
                        </div>
                        
                        <div class="input-group"><label>GENDER</label><select id="gender"><option>MALE</option><option>FEMALE</option></select></div>
                        <div class="input-group"><label>MOBILE NO.</label><input type="text" id="phone1" value="+91 "></div>
                        
                        <div class="input-group full-width">
                            <label>PERMANENT ADDRESS</label>
                            <input type="text" id="address" oninput="this.value = this.value.toUpperCase()">
                        </div>
                        
                        <div class="input-group full-width"><label>SCHOOL NAME</label>
                            <select id="schoolName">
                                <option value="">-- SELECT --</option>
                                <option>APNA BACHPAN</option>
                                <option>ARUN INTERNATIONAL SCHOOL</option>
                                <option>BSDAV PUBLIC SCHOOL</option>
                                <option>B.D. PUBLIC SCHOOL</option>
                                <option>CHANAKYA SCHOOL</option>
                                <option>CATHOLIC MISSION SCHOOL</option>
                                <option>CREED INTERNATIONAL SCHOOL</option>
                                <option>DAKSH CAREER SCHOOL</option>
                                <option>DAV PUBLIC SCHOOL</option>
                                <option>D.K CARMEL RESIDENTIAL HIGH SCHOOL</option>
                                <option>DELHI PUBLIC SCHOOL</option>
                                <option>G.D GOENKA SCHOOL</option>
                                <option>GURUKUL GROVE SCHOOL</option>
                                <option>GYAN GANGA RESIDENCIAL SCHOOL</option>
                                <option>GYAN JYITI AWASIYA VIDYALAYA</option>
                                <option>JEAN PAUL SENIOR SECONDARY SCHOOL</option>
                                <option>MOUNT LITERA ZEE SCHOOL</option>
                                <option>NEW UNIQUE RESIDENTIAL PUBLIC SCHOOL</option>
                                <option>PM SHRI KENDRIYA VIDYALAYA</option>
                                <option>RADIANT PROGRESSIVE SCHOOL</option>
                                <option>RADIANT PUBLIC SCHOOL</option>
                                <option>RAM KRISHNA GYAN MISSION</option>
                                <option>RNS DELHI PUBLIC SCHOOL</option>
                                <option>SAMBHAWNA</option>
                                <option>SIXTH SENSE INTERNATIONAL SCHOOL</option>
                                <option>SONE VALLEY INTERNATIONAL SCHOOL</option>
                                <option>S.S UNIVERSAL INTERNATIONAL SCHOOL</option>
                                <option>SUN BEAM PUBLIC SCHOOL</option>
                                <option>ST. XAVIER SCHOOL</option>
                                <option>OTHER</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="photo-area">
                        <div class="photo-box" onclick="document.getElementById('photoUpload').click()">
                            <img id="previewImg" alt="Photo">
                            <p id="photoText">CLICK TO UPLOAD PHOTO</p>
                        </div>
                        <input type="file" id="photoUpload" hidden onchange="showPreview(event)" accept="image/*">
                    </div>
                </div>

                <div class="section-header" style="margin-top: 8px;"><span><i class="fa-solid fa-graduation-cap"></i> 02. COURSE & OFFICE DETAILS</span></div>
                <div class="fields-container" style="grid-template-columns: 1fr 1fr 1fr; margin-bottom: 8px;">
                    <div class="input-group">
                        <label>COURSE SELECTED</label>
                        <select id="courseSelect" onchange="updateCourseDetails()">
                            <option value="">-- SELECT --</option>
                            <option value="Plus & Minus">PLUS & MINUS</option>
                            <option value="PathFinder">PATHFINDER</option>
                            <option value="Foundation">FOUNDATION</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>CLASS</label>
                        <select id="classSelect" onchange="generateRollNo()"><option value="">-- SELECT --</option></select>
                    </div>
                    <div class="input-group">
                        <label>ROLL NUMBER</label>
                        <input type="text" id="rollNo" readonly style="color: #000; font-weight: 800; font-size: 14px;">
                    </div>
                </div>
                <div class="input-group full-width" style="margin-bottom: 8px;">
                    <label>SUBJECTS</label><input type="text" id="subjects" readonly style="font-weight: 600; color: #000;">
                </div>
                <div class="fields-container" style="grid-template-columns: 1fr 1fr 1fr;">
                    <div class="input-group"><label>COURSE FEE (ANNUALLY)</label><input type="text" id="feeAmount" readonly placeholder="₹ 0"></div>
                    <div class="input-group"><label>SESSION START</label><input type="text" id="startDate" readonly></div>
                    <div class="input-group"><label>SESSION END</label><input type="text" id="endDate" readonly></div>
                </div>
            </div> 
            
            <div> 
                <div class="signatures">
                    <div class="sig-line">Parent's Signature</div>
                    <div class="sig-line">Student's Signature</div>
                    <div class="sig-line">Center Head Signature</div>
                </div>

                <footer class="form-footer">
                    <p><strong>ADDRESS:</strong> SOUTH BHELAI ROAD, KRISHNA NAGAR, (NEAR MAHAVIR MANDIR) ARA 802312</p>
                    <p>CONTACT: +91 7011615622 | EMAIL: THESTUDYHOME2025@GMAIL.COM</p>
                </footer>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, doc, getDoc, setDoc, collection, getCountFromServer, query, where, getDocs } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";
        import { getStorage, ref, uploadBytes, getDownloadURL } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-storage.js";

        const firebaseConfig = { apiKey: "AIzaSyCkidlwsrP3azbAT0Gon6ZuPxzpM7wU_bQ", authDomain: "thestudyhome.firebaseapp.com", projectId: "thestudyhome", storageBucket: "thestudyhome.firebasestorage.app", messagingSenderId: "820716939260", appId: "1:820716939260:web:4c26778db33fc23fe87479", measurementId: "G-74JTVT8CDD" };
        const app = initializeApp(firebaseConfig); const db = getFirestore(app); const storage = getStorage(app);

        let currentSessionCode = "";
        let finalRegId = "";

        // 1. INIT
        window.initPage = async function() {
            const today = new Date();
            const year = today.getFullYear();
            const month = today.getMonth(); 
            let startYear = (month < 3) ? year - 1 : year;
            let endYear = startYear + 1;

            const sYearShort = startYear.toString().slice(-2);
            const eYearShort = endYear.toString().slice(-2);
            currentSessionCode = sYearShort + eYearShort; 

            document.getElementById('sessionDisplay').innerText = `SESSION: ${startYear}-${endYear}`;
            document.getElementById('startDate').value = `01 APRIL ${startYear}`;
            document.getElementById('endDate').value = `31 MARCH ${endYear}`;

            // CHECK URL PARAMETERS (RE-PRINT MODE)
            const urlParams = new URLSearchParams(window.location.search);
            const loadId = urlParams.get('id');

            if (loadId) {
                // LOAD EXISTING STUDENT
                document.getElementById('saveBtn').style.display = 'none'; // Hide Save
                document.getElementById('regId').value = loadId;
                await loadExistingStudent(loadId);
            } else {
                // NEW ADMISSION
                const admDateInput = document.getElementById('admissionDate');
                if(admDateInput && !admDateInput.value) admDateInput.valueAsDate = new Date();
                generateNewId();
            }
        };

        window.generateNewId = async function() {
            try {
                const coll = collection(db, "students");
                const snapshot = await getCountFromServer(coll);
                const count = snapshot.data().count + 1;
                finalRegId = `TSH${currentSessionCode}${count.toString().padStart(4, '0')}`;
                document.getElementById('regId').value = finalRegId;
            } catch (error) { console.error(error); }
        }

        window.loadExistingStudent = async function(id) {
            try {
                const q = query(collection(db, "students"), where("regId", "==", id));
                const querySnapshot = await getDocs(q);
                
                let data = null;
                if (!querySnapshot.empty) {
                    data = querySnapshot.docs[0].data();
                } else {
                    const docRef = doc(db, "students", id);
                    const snap = await getDoc(docRef);
                    if(snap.exists()) data = snap.data();
                }

                if (data) {
                    document.getElementById('studentName').value = data.name || "";
                    document.getElementById('admissionDate').value = data.admissionDate || "";
                    document.getElementById('dob').value = data.dob || "";
                    document.getElementById('fatherName').value = data.father || "";
                    document.getElementById('motherName').value = data.mother || "";
                    document.getElementById('gender').value = data.gender || "MALE";
                    document.getElementById('phone1').value = data.phone || "";
                    document.getElementById('address').value = data.address || "";
                    document.getElementById('schoolName').value = data.school || "";
                    
                    document.getElementById('courseSelect').value = data.course || "";
                    window.updateCourseDetails(); // This loads standard classes (1st to 10th)
                    
                    // --- THE FIX FOR "PASSED OUT 2026" BLANKING ---
                    let classVal = data.class || "";
                    let classSelect = document.getElementById('classSelect');
                    let optionExists = Array.from(classSelect.options).some(opt => opt.value === classVal);
                    
                    // If the class (e.g. PASSED OUT 2026) isn't in the default dropdown list, we force add it so it displays!
                    if (!optionExists && classVal !== "") {
                        classSelect.add(new Option(classVal, classVal));
                    }
                    classSelect.value = classVal;
                    // ----------------------------------------------
                    
                    document.getElementById('rollNo').value = data.rollNo || "";
                    document.getElementById('feeAmount').value = data.fee || "";

                    if (data.photo) {
                        document.getElementById("previewImg").src = data.photo;
                        document.getElementById("previewImg").style.display = "block";
                        document.getElementById("photoText").style.display = "none";
                    }
                    
                    document.title = `Form - ${data.name}`;
                } else {
                    alert("Student Data Not Found in Database!");
                }
            } catch (e) {
                console.error("Error loading student:", e);
            }
        }

        // 2. PREVIEW PHOTO
        window.showPreview = function(event) {
            if(event.target.files.length > 0){
                let src = URL.createObjectURL(event.target.files[0]);
                document.getElementById("previewImg").src = src;
                document.getElementById("previewImg").style.display = "block";
                document.getElementById("photoText").style.display = "none";
            }
        }

        // 3. COURSE LOGIC
        window.updateCourseDetails = function() {
            const course = document.getElementById('courseSelect').value;
            const classSelect = document.getElementById('classSelect');
            const feeInput = document.getElementById('feeAmount');
            const subjectInput = document.getElementById('subjects');
            
            classSelect.innerHTML = '<option value="">-- SELECT CLASS --</option>';

            if (course === "Plus & Minus") {
                ["NURSERY", "LKG", "UKG", "FIRST", "SECOND"].forEach(c => classSelect.add(new Option(c, c)));
                feeInput.value = "₹ 4800"; subjectInput.value = "ALL SUBJECT";
            } 
            else if (course === "PathFinder") {
                ["THIRD", "FOURTH", "FIFTH", "SIXTH"].forEach(c => classSelect.add(new Option(c, c)));
                feeInput.value = "₹ 6000"; subjectInput.value = "MATHEMATICS, SCIENCE, ENGLISH, SOCIAL STUDIES & COMPUTER";
            } 
            else if (course === "Foundation") {
                ["SEVENTH", "EIGHTH", "NINTH", "TENTH"].forEach(c => classSelect.add(new Option(c, c)));
                feeInput.value = "₹ 7200"; subjectInput.value = "MATHEMATICS, SCIENCE, ENGLISH, SOCIAL STUDIES";
            }
        }

        // 4. GENERATE ROLL NO
        window.generateRollNo = async function() {
            if(document.getElementById('regId').value.includes("TSH")) {
                const urlParams = new URLSearchParams(window.location.search);
                if(urlParams.get('id')) return; 
            }

            const course = document.getElementById('courseSelect').value;
            const classVal = document.getElementById('classSelect').value;
            const rollInput = document.getElementById('rollNo');

            if(!course || !classVal) return;

            rollInput.value = "CALCULATING...";
            let code = (course === "Plus & Minus") ? "PM" : (course === "PathFinder") ? "PF" : "PW";
            
            const classMap = { "NURSERY":"00", "LKG":"LG", "UKG":"UG", "FIRST":"01", "SECOND":"02", "THIRD":"03", "FOURTH":"04", "FIFTH":"05", "SIXTH":"06", "SEVENTH":"07", "EIGHTH":"08", "NINTH":"09", "TENTH":"10" };
            let classCode = classMap[classVal] || "00";

            try {
                const coll = collection(db, "students");
                const q = query(coll, where("class", "==", classVal)); 
                const snapshot = await getCountFromServer(q);
                const nextRollSeq = snapshot.data().count + 1;
                const formattedSeq = nextRollSeq.toString().padStart(2, '0');
                rollInput.value = `${code}${classCode}${formattedSeq}`;
            } catch(error) { rollInput.value = `${code}${classCode}01`; }
        }

        function getVal(id) { const el = document.getElementById(id); return el ? el.value : ""; }

        // 6. SAVE FUNCTION
        window.saveToCloud = async function() {
            const btn = document.getElementById("saveBtn");
            const msg = document.getElementById("statusMsg");
            
            try {
                const name = getVal("studentName");
                const dob = getVal("dob");
                if(!name || !dob) { alert("Please fill Name and DOB!"); return; }

                btn.disabled = true; btn.innerText = "Processing...";
                msg.innerText = "Uploading Photo..."; msg.style.color = "blue";

                let photoUrl = "";
                const fileInput = document.getElementById("photoUpload");
                if(fileInput && fileInput.files[0]) {
                    const file = fileInput.files[0];
                    const storageRef = ref(storage, 'student_photos/' + finalRegId + '_' + file.name);
                    await uploadBytes(storageRef, file);
                    photoUrl = await getDownloadURL(storageRef);
                }

                msg.innerText = "Saving Data...";
                const password = dob.split('-').reverse().join(''); 

                const studentData = {
                    regId: finalRegId,
                    name: name.toUpperCase(),
                    dob: dob,
                    password: password,
                    father: getVal("fatherName").toUpperCase(),
                    mother: getVal("motherName").toUpperCase(),
                    gender: getVal("gender"),
                    admissionDate: getVal("admissionDate"),
                    phone: getVal("phone1"),
                    school: getVal("schoolName"),
                    course: getVal("courseSelect"),
                    class: getVal("classSelect"),
                    rollNo: getVal("rollNo"),
                    fee: getVal("feeAmount"),
                    address: getVal("address").toUpperCase(),
                    photo: photoUrl,
                    status: "Active",
                    sessionCode: currentSessionCode
                };

                await setDoc(doc(db, "students", finalRegId), studentData);

                msg.innerText = "Success! Data Saved."; msg.style.color = "green";
                alert(`Student Registered!\nID: ${finalRegId}\nRoll No: ${studentData.rollNo}\nPassword: ${password}`);
                
                btn.innerText = "SAVED";
                window.print();

            } catch (error) {
                msg.innerText = "Error: " + error.message; msg.style.color = "red";
                alert("Error Saving: " + error.message);
                btn.disabled = false; btn.innerText = "Retry Save";
            }
        }

        window.onload = window.initPage;
    </script>
</body>
</html>
